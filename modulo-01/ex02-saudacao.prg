FUNCTION Main()
    //O comando LOCAL cria variáveis para guardar textos (tipo caractere)
    LOCAL cNome   := "Fernanda Luz"
    LOCAL cCidade := "Campinas"
    LOCAL cFrase  := "Pronta para aprender ADVPL!"

    QOut("Nome   : " + cNome)
    QOut("Cidade : " + cCidade)
    QOut(cFrase)     // Mostra o conteúdo completo da variável cFrase na tela
RETURN NIL